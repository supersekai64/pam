{
  "name": "pamh",
  "version": "0.1.0",
  "description": "PAMH CLI - Command line interface for PAMH",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supersekai64/pamh.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/supersekai64/pamh#readme",
  "bugs": {
    "url": "https://github.com/supersekai64/pamh/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "mcp",
    "cli"
  ],
  "bin": {
    "memory": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pamh-api": "workspace:*",
    "pamh-core": "workspace:*",
    "pamh-mcp": "workspace:^",
    "commander": "^15.0.0"
  }
}
